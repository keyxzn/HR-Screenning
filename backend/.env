# Copy file ini jadi .env dan sesuaikan isinya

# App
APP_ENV=development
SECRET_KEY=ganti-dengan-random-string-panjang

# Database PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hr_checker

# Ollama (jalankan lokal: ollama serve && ollama pull llama3)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# CORS (URL frontend)
ALLOWED_ORIGINS=["http://localhost:3000"]
